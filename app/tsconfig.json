{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS", // ALTERE para CommonJS
    "moduleResolution": "node", // ALTERE para node
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false, // PRECISA emitir, senão ts-node não funciona direito
    "resolveJsonModule": true,
    "isolatedModules": true, // deixar false para rodar node/ts-node
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
