generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" // ou "mysql" / "sqlite" conforme seu uso
  url      = env("DATABASE_URL")
}

model Fabricante {
  id        Int         @id @default(autoincrement())
  nome      String      @unique
  descricao String? // <-- adicione este campo
  site      String? // <-- adicione este campo
  linhas    Linha[]
  produtos  Produto[]
  Categoria Categoria[]
}

model Categoria {
  id           Int        @id @default(autoincrement())
  nome         String
  slug         String     @unique // Usado para rotas dinâmicas (ex: /categoria/piso-vinilico)
  descricao    String?
  fabricanteId Int
  fabricante   Fabricante @relation(fields: [fabricanteId], references: [id])
  produtos Produto[]
  linhas   Linha[]
}

model Linha {
  id           Int        @id @default(autoincrement())
  nome         String     @unique // <-- adicione o @unique
  descricao    String?
  fabricante   Fabricante @relation(fields: [fabricanteId], references: [id])
  fabricanteId Int
  categoria    Categoria  @relation(fields: [categoriaId], references: [id])
  categoriaId  Int
  produtos     Produto[]
}

model Produto {
  id            Int     @id @default(autoincrement())
  nome          String
  codigo        String? // SKU, referência ou código interno
  cor           String? // Ex: Carvalho Viena
  espessuraMm   Float? // Ex: 7.5 mm
  larguraMm     Float? // Ex: 187 mm
  comprimentoMm Float? // Ex: 1340 mm
  imagemUrl     String? // URL da imagem
  descricao     String? // Descrição completa do produto

  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  categoriaId Int

  fabricante   Fabricante @relation(fields: [fabricanteId], references: [id])
  fabricanteId Int

  linha   Linha? @relation(fields: [linhaId], references: [id])
  linhaId Int? // Pode ser nulo, se o produto não fizer parte de uma linha
}
