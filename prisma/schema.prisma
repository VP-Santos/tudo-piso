generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id                    BigInt                  @id(map: "category_pkey") @default(autoincrement())
  name                  String
  image                 String
  description           String
  slug                  String
  category_manufacturer category_manufacturer[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model category_manufacturer {
  id              BigInt          @id(map: "manufacturer_category_pkey") @default(autoincrement())
  manufacturer_id BigInt
  category_id     BigInt
  categories      categories      @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "manufacturer_categories_category_id_fkey")
  manufacturers   manufacturers   @relation(fields: [manufacturer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "manufacturer_categories_manufacturer_id_fkey")
  product_lines   product_lines[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model manufacturers {
  id                    BigInt                  @id @default(autoincrement())
  name                  String                  @db.VarChar
  description           String
  origin                String                  @db.VarChar
  image_path            String
  slug                  String
  category_manufacturer category_manufacturer[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_lines {
  id                       BigInt                @id @default(autoincrement())
  name                     String                @db.VarChar
  width                    Float
  length                   Float
  category_manufacturer_id BigInt
  image_path               String
  slug                     String
  thickness                String?
  description              String?
  category_manufacturer    category_manufacturer @relation(fields: [category_manufacturer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products                 products[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id                      BigInt                    @id @default(autoincrement())
  product_line_id         BigInt
  name                    String                    @db.VarChar
  code                    String
  image_path              String
  slug                    String
  installations_performed installations_performed[]
  product_lines           product_lines             @relation(fields: [product_line_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model installations_performed {
  id                  BigInt                @id @default(autoincrement())
  product_id          BigInt
  image_path          String
  images_istallations images_istallations[]
  products            products              @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model images_istallations {
  id                         BigInt                  @id(map: "Images_istallations_pkey") @default(autoincrement())
  installations_performed_id BigInt
  image_path                 String
  installations_performed    installations_performed @relation(fields: [installations_performed_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Images_istallations_installations_performed_id_fkey")
}
